	},
	"homepage": "https://github.com/hansdoebel/n8n-nodes-monday-pro#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/hansdoebel/n8n-nodes-monday-pro.git"
	},
	"bugs": {
		"url": "https://github.com/hansdoebel/n8n-nodes-monday-pro/issues"
	},
	"funding": {
		"type": "buymeacoffee",
		"url": "https://buymeacoffee.com/hansdoebel"
	},
